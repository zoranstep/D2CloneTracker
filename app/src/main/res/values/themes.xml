<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.D2CloneTracker" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#9B2335</item>
        <item name="colorPrimaryDark">#0D0D1A</item>
        <item name="colorAccent">#9B2335</item>
        <item name="android:windowBackground">#0D0D1A</item>
        <item name="android:statusBarColor">#1A1A2E</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:textColorPrimary">#EEEEEE</item>
        <item name="android:textColorSecondary">#AAAACC</item>
        <item name="actionOverflowMenuStyle">@style/OverflowMenuStyle</item>
    </style>

    <style name="Theme.D2CloneTracker.Splash" parent="Theme.D2CloneTracker">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:statusBarColor">#0D0D1A</item>
    </style>

    <style name="OverflowMenuStyle" parent="Widget.AppCompat.PopupMenu.Overflow">
        <item name="overlapAnchor">false</item>
        <item name="android:popupBackground">#1A1A2E</item>
        <item name="android:textColor">#EEEEEE</item>
    </style>
</resources>
