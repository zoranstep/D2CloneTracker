<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D1A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Status bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">
            <TextView
                android:id="@+id/tvTZStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Loading..."
                android:textColor="#AAAACC"
                android:textSize="12sp" />
            <TextView
                android:id="@+id/tvTZLastUpdated"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#555577"
                android:textSize="11sp" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/tzProgressBar"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            style="?android:attr/progressBarStyleHorizontal"
            android:indeterminate="true"
            android:progressTint="#9B2335"
            android:visibility="gone"
            android:layout_marginBottom="12dp"/>

        <!-- Terror Zone Info Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="4dp"
            android:backgroundTint="#1A1A2E">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Current Terror Zone"
                    android:textColor="#9B2335"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvCurrentTZ"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="16dp"
                    android:text="Fetching..."
                    android:textColor="#EEEEEE"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#2A2A3E"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Next Terror Zone"
                    android:textColor="#888899"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvNextTZ"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Fetching..."
                    android:textColor="#EEEEEE"
                    android:textSize="22sp"
                    android:textStyle="bold" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Debug Raw Text -->
        <TextView
            android:id="@+id/tvTZRawDebug"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:textColor="#444466"
            android:textSize="10sp"
            android:text=""
            android:visibility="gone" />

        <!-- Action buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnTZRefresh"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="Refresh"
                android:textColor="#FFFFFF"
                android:textAllCaps="false"
                android:backgroundTint="#2A2A3E" />

            <Button
                android:id="@+id/btnTZAlertSettings"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="🔔 Zone Alerts"
                android:textColor="#FFFFFF"
                android:textAllCaps="false"
                android:backgroundTint="#9B2335" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvTZCredit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:paddingBottom="16dp"
            android:text="Data courtesy of d2tz.info"
            android:textColor="#8888AA"
            android:textSize="13sp"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>
</ScrollView>
